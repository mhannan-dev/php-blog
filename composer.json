{
    "name": "mhannan-dev/php-blog",
    "type": "project",
    "authors": [
        {
            "name": "Muhammad Hannan",
            "email": "mdhannan.info@gmail.com"
        }
    ],
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "doctrine/dbal": "^3.9",
        "doctrine/migrations": "^3.8",
        "twig/twig": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "app/Database/Migrations"
        ]
    },
    "scripts": {
        "start": "php -S localhost:8888",
        "migrate": "php bin/migrate migrate --no-interaction",
        "migrate:fresh": "php bin/migrate-fresh",
        "migrate:status": "php bin/migrate status",
        "migrate:gen": "php bin/migrate generate",
        "migrate:diff": "php bin/migrate diff",
        "make:model": "php bin/make-model",
        "make:migration": "php bin/make-migration",
        "migrate:down": "php bin/migrate execute --down --all --no-interaction",
        "db:seed": "php db-seed.php"
    }
}