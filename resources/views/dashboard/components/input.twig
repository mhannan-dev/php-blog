{# 
    Reusable Form Input Components for Admin Dashboard
    Usage:
    {% import 'dashboard/components/input.twig' as form %}
    
    {{ form.text('username', 'Username', value, 'Enter username...', true) }}
    {{ form.password('password', 'Password', true) }}
    {{ form.textarea('body', 'Content', value, 'tinymce', true) }}
    {{ form.select('role', 'User Role', {'0': 'Admin', '1': 'Author'}, '0', true) }}
#}

{% macro text(name, label, value='', placeholder='', required=false, type='text', id='', icon='') %}
    {% set inputId = id ? id : name %}
    <div class="flex flex-col gap-1.5 w-full">
        <label for="{{ inputId }}" class="text-xs font-semibold uppercase tracking-wider text-slate-400">{{ label }}</label>
        <div class="relative w-full flex items-center">
            <input type="{{ type }}" name="{{ name }}" id="{{ inputId }}" placeholder="{{ placeholder }}" 
                   class="w-full bg-slate-900 border border-white/10 rounded-xl py-3 pr-4 {{ icon ? 'pl-11' : 'pl-4' }} text-sm text-slate-200 placeholder-slate-655 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all duration-200"
                   value="{{ value }}" {{ required ? 'required' : '' }} />
            {% if icon %}
                <i class="{{ icon }} absolute left-4 text-slate-500 text-sm"></i>
            {% endif %}
        </div>
    </div>
{% endmacro %}

{% macro password(name, label, required=false, id='', icon='') %}
    {% set inputId = id ? id : name %}
    <div class="flex flex-col gap-1.5 w-full">
        <label for="{{ inputId }}" class="text-xs font-semibold uppercase tracking-wider text-slate-400">{{ label }}</label>
        <div class="relative w-full flex items-center">
            <input type="password" name="{{ name }}" id="{{ inputId }}" placeholder="••••••••" 
                   class="w-full bg-slate-900 border border-white/10 rounded-xl py-3 pr-12 {{ icon ? 'pl-11' : 'pl-4' }} text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all duration-200"
                   {{ required ? 'required' : '' }} />
            {% if icon %}
                <i class="{{ icon }} absolute left-4 text-slate-500 text-sm"></i>
            {% endif %}
            <button type="button" tabindex="-1" onclick="const p = this.previousElementSibling{{ icon ? '.previousElementSibling' : '' }}; p.type = p.type === 'password' ? 'text' : 'password'; this.querySelector('i').classList.toggle('fa-eye'); this.querySelector('i').classList.toggle('fa-eye-slash');" class="absolute right-4 text-slate-500 hover:text-slate-300 focus:outline-none cursor-pointer transition-colors duration-200">
                <i class="fa-solid fa-eye"></i>
            </button>
        </div>
    </div>
{% endmacro %}

{% macro textarea(name, label, value='', classes='', required=false, id='') %}
    {% set inputId = id ? id : name %}
    <div class="flex flex-col gap-1.5 w-full">
        <label for="{{ inputId }}" class="text-xs font-semibold uppercase tracking-wider text-slate-400">{{ label }}</label>
        <textarea name="{{ name }}" id="{{ inputId }}" class="w-full bg-slate-900 border border-white/10 rounded-xl px-4 py-3 text-sm text-slate-200 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all duration-200 {{ classes }}" {{ required ? 'required' : '' }}>{{ value }}</textarea>
    </div>
{% endmacro %}

{% macro file(name, label, hint='', required=false, id='') %}
    {% set inputId = id ? id : name %}
    <div class="flex flex-col gap-1.5 w-full">
        <label for="{{ inputId }}" class="text-xs font-semibold uppercase tracking-wider text-slate-400">{{ label }}</label>
        <div class="w-full bg-slate-900 border border-white/10 rounded-xl p-4 flex flex-col gap-2">
            <input type="file" name="{{ name }}" id="{{ inputId }}" class="text-sm text-slate-400 cursor-pointer file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-blue-500/10 file:text-blue-400 hover:file:bg-blue-500/20 file:transition-colors" {{ required ? 'required' : '' }} />
            {% if hint %}
            <span class="text-[11px] text-slate-500">{{ hint }}</span>
            {% endif %}
        </div>
    </div>
{% endmacro %}

{% macro select(name, label, options, selected='', required=false, id='', icon='') %}
    {% set inputId = id ? id : name %}
    <div class="flex flex-col gap-1.5 w-full">
        <label for="{{ inputId }}" class="text-xs font-semibold uppercase tracking-wider text-slate-400">{{ label }}</label>
        <div class="relative w-full flex items-center">
            <select name="{{ name }}" id="{{ inputId }}" class="w-full bg-slate-900 border border-white/10 rounded-xl py-3 pr-4 {{ icon ? 'pl-11' : 'pl-4' }} text-sm text-slate-200 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all duration-200 appearance-none" {{ required ? 'required' : '' }}>
                <option value="">— Select {{ label }} —</option>
                {% for value, text in options %}
                    <option value="{{ value }}" {{ selected == value ? 'selected' : '' }}>{{ text }}</option>
                {% endfor %}
            </select>
            {% if icon %}
                <i class="{{ icon }} absolute left-4 text-slate-500 text-sm pointer-events-none"></i>
            {% endif %}
            <i class="fa-solid fa-chevron-down absolute right-4 text-slate-500 text-xs pointer-events-none"></i>
        </div>
    </div>
{% endmacro %}
