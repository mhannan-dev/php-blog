</body>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Dropdown Menu Toggles
        const toggles = document.querySelectorAll('.toggle-menu');
        toggles.forEach(toggle => {
            toggle.addEventListener('click', () => {
                const list = toggle.nextElementSibling;
                const icon = toggle.querySelector('i');
                list.classList.toggle('hidden');
                icon.classList.toggle('rotate-180');
            });
        });

        // Global Sidebar Toggle
        const sidebarToggle = document.getElementById('sidebar-toggle');
        const sidebar = document.getElementById('main-sidebar');
        const mainContent = document.getElementById('main-content');
        
        if (sidebarToggle && sidebar && mainContent) {
            sidebarToggle.addEventListener('click', () => {
                if (sidebar.classList.contains('md:w-[15%]')) {
                    sidebar.classList.remove('md:w-[15%]', 'w-full');
                    sidebar.classList.add('hidden');
                    mainContent.classList.remove('md:w-[85%]');
                    mainContent.classList.add('w-full');
                } else {
                    sidebar.classList.remove('hidden');
                    sidebar.classList.add('md:w-[15%]', 'w-full');
                    mainContent.classList.remove('w-full');
                    mainContent.classList.add('md:w-[85%]');
                }
            });
        }
    });
</script>
</html>
